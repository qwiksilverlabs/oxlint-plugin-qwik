{
	"name": "oxlint-plugin-qwik",
	"version": "0.0.1",
	"private": false,
	"description": "An Oxlint plugin for Qwik",
	"keywords": [
		"linter",
		"oxc",
		"oxlint",
		"qwik"
	],
	"homepage": "https://github.com/qwiksilverlabs/oxlint-plugin-qwik",
	"bugs": {
		"url": "https://github.com/qwiksilverlabs/oxlint-plugin-qwik/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Toby Nguyen",
		"email": "hi@tobynguyen.net",
		"url": "https://tobynguyen.net"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/qwiksilverlabs/oxlint-plugin-qwik.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": "./dist/index.mjs",
		"./config": "./dist/config/index.mjs",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format": "oxfmt",
		"lint": "oxlint --type-aware --type-check",
		"lint:fix": "oxlint --fix",
		"test": "vitest"
	},
	"dependencies": {
		"@oxlint/plugins": "catalog:lint"
	},
	"devDependencies": {
		"oxfmt": "catalog:lint",
		"oxlint": "catalog:lint",
		"oxlint-tsgolint": "catalog:lint",
		"tsdown": "catalog:build",
		"typescript": "catalog:types",
		"vitest": "catalog:test"
	},
	"peerDependencies": {
		"oxlint": "catalog:lint"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.30.3"
}
