{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "esnext",
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",

		"strict": true,
		"noUncheckedIndexedAccess": true,

		"moduleResolution": "bundler",
		"module": "esnext",
		"noEmit": true,

		"lib": ["ESNext"],
		"declaration": true,
		"paths": {
			"@rules/*": ["./src/rules/*"]
		}
	},
	"include": ["src"]
}
